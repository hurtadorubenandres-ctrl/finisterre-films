# ─────────────────────────────────────────────────────────
#  Copia este archivo y renómbralo a: .env.local
#  Luego rellena los valores con los tuyos
# ─────────────────────────────────────────────────────────

# CLOUDINARY — lo encuentras en cloudinary.com > Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-nombre-de-cloud

# APP
NEXT_PUBLIC_APP_URL=https://tudominio.com

# BASE DE DATOS (MongoDB) — opcional, para más adelante
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/finisterre-films

# AUTENTICACIÓN — pon cualquier string secreto largo
NEXTAUTH_SECRET=cambia-esto-por-un-string-secreto-largo
NEXTAUTH_URL=https://tudominio.com
